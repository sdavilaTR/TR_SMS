<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ── WAITING STATE ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutWaiting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪪"
            android:textSize="64sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/passport_waiting_title"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/passport_waiting_hint"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Two scan buttons side by side -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLaserScanWaiting"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/scanner_btn_laser"
                android:textAllCaps="false"
                android:layout_marginEnd="12dp"
                app:icon="@drawable/ic_laser"
                app:iconGravity="textStart"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCameraScanWaiting"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/scanner_btn_camera"
                android:textAllCaps="false"
                app:icon="@drawable/ic_camera"
                app:iconGravity="textStart"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── LOADED STATE ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutLoaded"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Scan buttons bar at the top -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLaserScanLoaded"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/scanner_btn_laser"
                android:textAllCaps="false"
                android:layout_marginEnd="6dp"
                app:icon="@drawable/ic_laser"
                app:iconGravity="textStart"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCameraScanLoaded"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/scanner_btn_camera"
                android:textAllCaps="false"
                android:layout_marginStart="6dp"
                app:icon="@drawable/ic_camera"
                app:iconGravity="textStart"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Scrollable content area -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Passport card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Blue header band -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/passport_card_title"
                            android:textColor="@color/on_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.03" />

                        <TextView
                            android:id="@+id/txtScanTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Close button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClosePassport"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="✕"
                        android:textSize="14sp"
                        android:textColor="@color/on_primary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="18dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>

                <!-- Photo + name section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <!-- Photo (clickable to take photo) -->
                    <FrameLayout
                        android:id="@+id/photoContainer"
                        android:layout_width="90dp"
                        android:layout_height="115dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/bg_photo_placeholder"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <!-- Actual photo (shown when loaded) -->
                        <ImageView
                            android:id="@+id/imgWorkerPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <!-- Placeholder (shown when no photo) -->
                        <LinearLayout
                            android:id="@+id/layoutPhotoPlaceholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_person_placeholder"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/passport_photo_tap"
                                android:textColor="#78909C"
                                android:textSize="9sp"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Camera badge (bottom-right corner) -->
                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="bottom|end"
                            android:layout_margin="3dp"
                            android:background="@color/primary"
                            android:padding="4dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_camera" />
                        </FrameLayout>
                    </FrameLayout>

                    <!-- Name + status -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/passport_label_family_name"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="9sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/txtFamilyName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/passport_label_given_name"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="9sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/txtGivenName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:layout_marginBottom="8dp" />

                        <!-- Active status chip -->
                        <TextView
                            android:id="@+id/txtActiveStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginHorizontal="16dp" />

                <!-- Details grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp">

                    <!-- Row: Función / Compañía -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_position" android:textColor="@color/on_surface_variant" android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                            <TextView android:id="@+id/txtPosition" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_company" android:textColor="@color/on_surface_variant" android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                            <TextView android:id="@+id/txtCompany" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row: Documento / Categoría -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_document" android:textColor="@color/on_surface_variant" android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                            <TextView android:id="@+id/txtDocument" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_category" android:textColor="@color/on_surface_variant" android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                            <TextView android:id="@+id/txtCategory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row: Fecha de entrada / Válido hasta -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_valid_from" android:textColor="@color/on_surface_variant" android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                            <TextView android:id="@+id/txtValidFrom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_valid_to" android:textColor="@color/on_surface_variant" android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                            <TextView android:id="@+id/txtValidTo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Badge number strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/surface_variant"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/passport_label_badge"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/txtBadgeNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Trainings section ──────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_shield_check_24"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/passport_section_trainings"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTrainingsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Compliance progress -->
                <ProgressBar
                    android:id="@+id/progressTrainings"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/granted"
                    android:progressBackgroundTint="@color/divider"
                    android:layout_marginBottom="8dp" />

                <!-- Training items container -->
                <LinearLayout
                    android:id="@+id/layoutTrainingItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/txtNoTrainings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/passport_no_trainings"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingVertical="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Documentation section ────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_clipboard_check"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/passport_section_docs"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDocsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Compliance progress -->
                <ProgressBar
                    android:id="@+id/progressDocs"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/granted"
                    android:progressBackgroundTint="@color/divider"
                    android:layout_marginBottom="8dp" />

                <!-- Document items container -->
                <LinearLayout
                    android:id="@+id/layoutDocItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/txtNoDocs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/passport_no_docs"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingVertical="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        </LinearLayout>
        </ScrollView>

        <!-- Observation button - filled blue -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenObservation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/obs_open_observation"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            app:icon="@drawable/ic_observation"
            app:iconGravity="textStart"
            app:iconTint="@color/on_primary"
            app:cornerRadius="12dp" />

    </LinearLayout>
</FrameLayout>
