<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.example.hassiwrapper.ui.home.ParticleNetworkView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Connection status card (compact) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <!-- Network -->
                <View
                    android:id="@+id/dotNetwork"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_grey"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/txtNetworkStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sync_status_checking"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />

                <!-- API -->
                <View
                    android:id="@+id/dotApi"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_grey"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/txtApiStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sync_status_checking"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />

                <!-- Auth -->
                <View
                    android:id="@+id/dotAuth"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_grey"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/txtAuthStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sync_status_checking"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- KPI row: all 5 in a single horizontal card (compact) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <!-- Spools -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="3dp"
                        android:background="@color/primary"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/txtKpiRecords"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sync_kpi_records"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/txtKpiRecordsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="@color/divider" android:layout_marginHorizontal="2dp" />

                <!-- Packing Lists -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="3dp"
                        android:background="@color/primary"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/txtKpiPhotos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sync_kpi_photos"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/txtKpiPhotosLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="@color/divider" android:layout_marginHorizontal="2dp" />

                <!-- Vehículos -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="3dp"
                        android:background="@color/secondary"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/txtKpiObservations"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/secondary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sync_kpi_observations"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/txtKpiObservationsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="@color/divider" android:layout_marginHorizontal="2dp" />

                <!-- En Tránsito -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="3dp"
                        android:background="@color/warning"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/txtKpiWorkers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sync_kpi_workers"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/txtKpiWorkersLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="@color/divider" android:layout_marginHorizontal="2dp" />

                <!-- Pendientes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="3dp"
                        android:background="@color/granted"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/txtKpiVehicles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/granted" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sync_kpi_vehicles"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/txtKpiVehiclesLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sync button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFullSync"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/sync_btn"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:icon="@drawable/ic_sync"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- Progress indicator (indeterminate, shown while syncing) -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressSync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/primary"
            app:trackThickness="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Live sync log (shown during and after sync) -->
        <ScrollView
            android:id="@+id/scrollSyncLog"
            android:layout_width="match_parent"
            android:layout_height="164dp"
            android:visibility="gone"
            android:background="@drawable/bg_log_box"
            android:layout_marginBottom="8dp"
            android:fillViewport="true">
            <TextView
                android:id="@+id/txtSyncLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.5" />
        </ScrollView>

        <!-- Result card (shown after sync completes) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSyncResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:id="@+id/txtResultIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/txtResultTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtResultLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/txtResultWorkers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/txtResultVehicles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/txtResultObservations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/txtResultPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/txtResultError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Last sync timestamp -->
        <TextView
            android:id="@+id/txtLastSync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sync_last_none"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <!-- Hidden compat view, kept for legacy references -->
        <TextView
            android:id="@+id/txtSyncStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
</FrameLayout>
