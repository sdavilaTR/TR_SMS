<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.example.hassiwrapper.ui.home.ParticleNetworkView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- No ScrollView: the action-card section below shares whatever vertical space is left
         over (layout_height=0dp + weight), so the whole screen always fits without scrolling. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Header row: narrower terminal banner (+ sub-position breakdown filling the gap
             below it) on the left, the two zone KPIs stacked on the right. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <!-- Header card (gradient) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/headerCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/primary"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:id="@+id/headerContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_nav_header_gradient"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:id="@+id/txtGuestUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/txtGuestLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#CCffffff"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Per sub-position (GCP) breakdown — only populated/shown when the project
                     defines them. Sits in the gap left below the (shorter) banner, right next
                     to the pending/blue KPI card in the column beside it. -->
                <LinearLayout
                    android:id="@+id/guestSubPositionBreakdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Zone KPI stack: confirmed (synced) on top, pending (scanned, not yet synced)
                 below. Stretches to match the height of the banner+breakdown column. -->
            <LinearLayout
                android:id="@+id/guestZoneStatsRow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="5dp"
                    app:cardBackgroundColor="@color/granted_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/txtGuestZoneConfirmedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/green"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/txtGuestZoneConfirmedLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_guest_zone_confirmed"
                            android:textColor="@color/on_surface"
                            android:textSize="10sp"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/surface_variant"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/txtGuestZonePendingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_guest_zone_pending"
                            android:textColor="@color/on_surface"
                            android:textSize="10sp"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

        <!-- 3 action cards — share the remaining vertical space evenly (slightly smaller than
             before, since the header row above now also competes for room). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Enviar Spools -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGuestSend"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface_variant"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_kpi_primary"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_package_qr"
                                app:tint="@color/primary"
                                android:contentDescription="@null" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/home_qa_send"
                            android:textColor="@color/on_surface"
                            android:textSize="19sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recibir Spools -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGuestReceive"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/granted_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/green"
                app:strokeWidth="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="match_parent"
                        android:background="@color/green" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_kpi_green"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_download_24"
                                app:tint="@color/green"
                                android:contentDescription="@null" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/home_qa_transfers"
                            android:textColor="@color/on_surface"
                            android:textSize="19sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Nueva Incidencia -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGuestNewIncident"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/denied_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/error"
                app:strokeWidth="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="match_parent"
                        android:background="@color/error" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_kpi_error"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_alert_24"
                                app:tint="@color/error"
                                android:contentDescription="@null" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/home_qa_new_incident"
                            android:textColor="@color/on_surface"
                            android:textSize="19sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Bottom bar: sync gets its own full-width row so its label never gets squeezed by
             the icon buttons. Icon buttons share a second row, evenly spaced. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuestSync"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="@string/home_btn_sync"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:icon="@drawable/ic_sync"
            app:iconGravity="textStart"
            app:iconSize="22dp"
            app:iconPadding="6dp"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuestMap"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text=""
                app:icon="@drawable/ic_map_24"
                app:iconTint="@color/primary"
                app:iconSize="24dp"
                app:iconPadding="0dp"
                app:iconGravity="textStart"
                app:cornerRadius="16dp"
                android:contentDescription="@string/home_btn_map" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuestInventario"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text=""
                app:icon="@drawable/ic_clipboard_check"
                app:iconTint="@color/primary"
                app:iconSize="24dp"
                app:iconPadding="0dp"
                app:iconGravity="textStart"
                app:cornerRadius="16dp"
                android:contentDescription="@string/home_btn_inventario" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuestSettings"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text=""
                app:icon="@drawable/ic_settings"
                app:iconSize="24dp"
                app:iconPadding="0dp"
                app:iconGravity="textStart"
                app:cornerRadius="16dp"
                android:contentDescription="@string/menu_settings" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnGuestQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_qr_scan"
                app:backgroundTint="@color/green"
                app:fabCustomSize="52dp"
                app:maxImageSize="26dp"
                app:elevation="4dp"
                android:contentDescription="@string/qr_scan_button" />

        </LinearLayout>

    </LinearLayout>
</FrameLayout>
