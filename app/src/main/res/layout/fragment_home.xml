<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Stats Cards Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_workers" android:textColor="@color/on_surface_variant" android:textSize="12sp" android:letterSpacing="0.04" android:textAllCaps="true" />
                    <TextView android:id="@+id/txtWorkerCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/primary" android:textSize="32sp" android:textStyle="bold" android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_scans_today" android:textColor="@color/on_surface_variant" android:textSize="12sp" android:letterSpacing="0.04" android:textAllCaps="true" />
                    <TextView android:id="@+id/txtScansToday" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/secondary" android:textSize="32sp" android:textStyle="bold" android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Stats Cards Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_pending" android:textColor="@color/on_surface_variant" android:textSize="12sp" android:letterSpacing="0.04" android:textAllCaps="true" />
                    <TextView android:id="@+id/txtPendingCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/warning" android:textSize="32sp" android:textStyle="bold" android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_incidents" android:textColor="@color/on_surface_variant" android:textSize="12sp" android:letterSpacing="0.04" android:textAllCaps="true" />
                    <TextView android:id="@+id/txtIncidentCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/error" android:textSize="32sp" android:textStyle="bold" android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoScanner"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/home_btn_access"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoSync"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/home_btn_sync"
            android:textAllCaps="false"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp" />

        <TextView
            android:id="@+id/txtLastSync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_last_sync_none"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
