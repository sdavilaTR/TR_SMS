<?xml version="1.0" encoding="utf-8"?>
<com.example.hassiwrapper.ui.common.SwipeBackNestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Panel A: Scan Vehicle -->
        <LinearLayout
            android:id="@+id/panelScanVehicle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="6dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/primary"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="1"
                            android:gravity="center"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:background="@drawable/bg_step_badge"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transfer_receive_step1_title"
                            android:textColor="@color/on_primary"
                            android:textStyle="bold"
                            android:textSize="16sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/txtScannedVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnScanVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/transfer_btn_scan_vehicle"/>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Panel B: Select Packing List -->
        <LinearLayout
            android:id="@+id/panelSelectPl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="6dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/secondary"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/secondary"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="2"
                            android:gravity="center"
                            android:textColor="@color/secondary"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:background="@drawable/bg_step_badge"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transfer_receive_step2_title"
                            android:textColor="@color/on_primary"
                            android:textStyle="bold"
                            android:textSize="16sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                    <TextView
                        android:id="@+id/txtNoPls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_receive_no_pls"
                        android:visibility="gone"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPackingLists"
                        android:layoutAnimation="@anim/layout_animation_fall_down"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Panel C: Confirm Spools -->
        <LinearLayout
            android:id="@+id/panelConfirmSpools"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="6dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/green"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/green"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="3"
                            android:gravity="center"
                            android:textColor="@color/green"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:background="@drawable/bg_step_badge"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transfer_receive_step3_title"
                            android:textColor="@color/on_primary"
                            android:textStyle="bold"
                            android:textSize="16sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                    <TextView
                        android:id="@+id/txtSpoolsProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSpoolsToConfirm"
                        android:layoutAnimation="@anim/layout_animation_fall_down"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScanSpool"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/transfer_btn_scan_spool"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfirmReceive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/transfer_receive_btn_confirm"/>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</com.example.hassiwrapper.ui.common.SwipeBackNestedScrollView>
