<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.example.hassiwrapper.ui.home.ParticleNetworkView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="top"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Gradient header card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="@color/primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">
                <LinearLayout
                    android:id="@+id/headerContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_nav_header_gradient"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtTerminalName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                        <TextView
                            android:id="@+id/txtTerminalLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#CCffffff"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp"
                            android:visibility="gone" />
                    </LinearLayout>
                    <com.example.hassiwrapper.ui.home.TechOrbView
                        android:id="@+id/techOrbView"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Cards Row 1: Spools + Packing Lists -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSpools"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_kpi_primary"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_spool"
                                app:tint="@color/primary"
                                android:contentDescription="@null" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:id="@+id/txtSpoolCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_label_spools"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPackingLists"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_kpi_success"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_clipboard_check"
                                app:tint="@color/secondary"
                                android:contentDescription="@null" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:id="@+id/txtPackingListCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/secondary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_label_packing_lists"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Stats Cards Row 2: Vehicles + Critical Incidents -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="2dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardVehicles"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_kpi_success"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_truck_24"
                                app:tint="@color/secondary"
                                android:contentDescription="@null" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:id="@+id/txtVehicleCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/secondary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_label_vehicles"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCriticalIncidents"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_kpi_error"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_alert_24"
                                app:tint="@color/error"
                                android:contentDescription="@null" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:id="@+id/txtCriticalIncidentCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/error"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_label_critical_incidents"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Quick Actions Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_quick_actions_title"
                android:textColor="@color/on_surface"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingStart="6dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="2dp" />

            <!-- Quick Actions: left column (4 normal cards) + right column (Recibir + Nueva Incidencia spanning 2 slots) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <!-- Left column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickSend"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_kpi_warning"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_package_qr"
                                    app:tint="@color/warning"
                                    android:contentDescription="@null" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/home_qa_send"
                                android:textColor="@color/on_surface"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickNewPl"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_kpi_purple"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_clipboard_check"
                                    app:tint="@color/purple"
                                    android:contentDescription="@null" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/home_qa_new_pl"
                                android:textColor="@color/on_surface"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickNewSpool"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_kpi_gray"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_spool"
                                    app:tint="@color/graphite"
                                    android:contentDescription="@null" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/home_qa_new_spool"
                                android:textColor="@color/on_surface"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickNewVehicle"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_kpi_success"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_truck_24"
                                    app:tint="@color/secondary"
                                    android:contentDescription="@null" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/home_qa_new_vehicle"
                                android:textColor="@color/on_surface"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Right column: Recibir (1 slot) + Nueva Incidencia (2 slots) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickTransfers"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_kpi_green"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_download_24"
                                    app:tint="@color/green"
                                    android:contentDescription="@null" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/home_qa_transfers"
                                android:textColor="@color/on_surface"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickNewIncident"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_kpi_error"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_alert_24"
                                    app:tint="@color/error"
                                    android:contentDescription="@null" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/home_qa_new_incident"
                                android:textColor="@color/on_surface"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickMap"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_kpi_primary"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_map_24"
                                    app:tint="@color/primary"
                                    android:contentDescription="@null" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/home_qa_map"
                                android:textColor="@color/on_surface"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoSync"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/home_btn_sync"
                android:textAllCaps="false"
                android:layout_marginBottom="5dp"
                app:icon="@drawable/ic_sync"
                app:iconGravity="textStart"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeProject"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/home_btn_change_project"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginBottom="2dp"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/txtProjectLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="1dp" />

            <TextView
                android:id="@+id/txtLastSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_last_sync_none"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
