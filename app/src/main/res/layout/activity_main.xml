<?xml version="1.0" encoding="utf-8"?>
<com.example.hassiwrapper.ui.common.WideEdgeDrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Main content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top App Bar -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/primary"
                android:elevation="4dp"
                android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
                app:title="Smart Material System"
                app:titleTextColor="@color/on_primary"
                app:navigationIconTint="@color/on_primary"
                app:navigationIcon="@drawable/ic_menu" />

            <!-- NavHost -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/navHostFragment"
                android:name="androidx.navigation.fragment.NavHostFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:defaultNavHost="true"
                app:navGraph="@navigation/nav_graph" />

        </LinearLayout>

        <!-- Global keyboard-wedge capture for hardware scanner on non-QrScanner screens -->
        <EditText
            android:id="@+id/etGlobalWedge"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:alpha="0"
            android:inputType="textMultiLine"
            android:maxLines="50"
            android:background="@null"
            android:importantForAutofill="no" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabQrScan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="16dp"
            android:src="@drawable/ic_qr_scan"
            android:contentDescription="@string/qr_scan_button"
            app:backgroundTint="@color/green"
            app:elevation="6dp" />

    </FrameLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        android:fitsSystemWindows="false"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemTextColor="@color/on_surface"
        app:itemIconTint="@color/primary"
        app:itemRippleColor="@color/ripple"
        app:itemHorizontalPadding="20dp"
        app:itemIconPadding="12dp" />

</com.example.hassiwrapper.ui.common.WideEdgeDrawerLayout>
