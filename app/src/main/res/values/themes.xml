<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Atlas" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorError">@color/error</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>
        <item name="spinnerStyle">@style/Widget.Atlas.Spinner</item>

        <!-- Unified shape system: rounds buttons, text fields, dialogs, sheets,
             menus app-wide without touching every layout. -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Atlas.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Atlas.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Atlas.LargeComponent</item>

        <!-- Default card look: soft elevation, rounded, no harsh outline -->
        <item name="materialCardViewStyle">@style/Widget.Atlas.CardView</item>
        <item name="cardViewStyle">@style/Widget.Atlas.CardView.Plain</item>

        <!-- Press feedback -->
        <item name="colorControlHighlight">@color/ripple</item>
    </style>

    <style name="Theme.Atlas.FullScreen" parent="Theme.Atlas">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Widget.Atlas.Spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@color/surface_variant</item>
        <item name="android:padding">8dp</item>
    </style>

    <!-- Shape tokens: 12dp buttons/inputs, 14dp medium surfaces, 20dp sheets/dialogs -->
    <style name="ShapeAppearance.Atlas.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Atlas.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearance.Atlas.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Widget.Atlas.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="rippleColor">@color/ripple</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.Atlas.CardView.Plain" parent="CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>
