<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ── WAITING STATE ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutWaiting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪪"
            android:textSize="64sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/passport_waiting_title"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/passport_waiting_hint"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCameraScanWaiting"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/scanner_btn_camera"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>

    <!-- ── LOADED STATE ──────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/layoutLoaded"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Passport card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Blue header band -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/primary"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/passport_card_title"
                                android:textColor="@color/on_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.03" />

                            <TextView
                                android:id="@+id/txtScanTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Close button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClosePassport"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="✕"
                            android:textSize="16sp"
                            android:textColor="@color/on_primary"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="20dp"
                            style="@style/Widget.MaterialComponents.Button.TextButton" />
                    </LinearLayout>

                    <!-- Photo + name section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <!-- Photo (clickable to take photo) -->
                        <FrameLayout
                            android:id="@+id/photoContainer"
                            android:layout_width="100dp"
                            android:layout_height="130dp"
                            android:layout_marginEnd="16dp"
                            android:background="@color/surface_variant"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/imgWorkerPhoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/txtPhotoPlaceholder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="👤"
                                android:textSize="40sp" />

                            <!-- Camera overlay icon -->
                            <TextView
                                android:id="@+id/txtCameraHint"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom"
                                android:background="#88000000"
                                android:gravity="center"
                                android:paddingVertical="4dp"
                                android:text="📷"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <!-- Name + status -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/passport_label_family_name"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/txtFamilyName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/on_surface"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/passport_label_given_name"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/txtGivenName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/on_surface"
                                android:textSize="18sp"
                                android:layout_marginBottom="10dp" />

                            <!-- Active status chip -->
                            <TextView
                                android:id="@+id/txtActiveStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp" />

                    <!-- Details grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp">

                        <!-- Row: Función / Compañía -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_position" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                                <TextView android:id="@+id/txtPosition" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="15sp" android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_company" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                                <TextView android:id="@+id/txtCompany" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="15sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row: Documento / Fecha de entrada -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_document" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                                <TextView android:id="@+id/txtDocument" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="15sp" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_valid_from" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                                <TextView android:id="@+id/txtValidFrom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="15sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row: Categoría / Válido hasta -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_category" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                                <TextView android:id="@+id/txtCategory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="15sp" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/passport_label_valid_to" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.05" />
                                <TextView android:id="@+id/txtValidTo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/on_surface" android:textSize="15sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Badge number strip -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/surface_variant"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/passport_label_badge"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/txtBadgeNumber"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- QR placeholder -->
                        <LinearLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="@color/divider"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="▦"
                                android:textSize="32sp"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Camera scan button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCameraScanLoaded"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/scanner_btn_camera"
                android:textAllCaps="false"
                android:layout_marginTop="12dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
